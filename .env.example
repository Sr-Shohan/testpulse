# ─── Data source ─────────────────────────────────────────────
# "demo"    → built-in synthetic dataset (default, no external services)
# "jenkins" → live Jenkins API (requires the JENKINS_* vars below)
DATA_SOURCE=demo

# ─── Jenkins (only needed when DATA_SOURCE=jenkins) ──────────
# Base URL of the Jenkins parent job / multi-branch pipeline folder.
# JENKINS_BASE_URL=https://your-jenkins.example.com/job/your-pipeline
# JENKINS_USER=your_username
# JENKINS_TOKEN=your_api_token
